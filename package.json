        "@sentry/node": "^10.40.0",
        "@tanstack/react-query": "^5.90.21",
        "@trpc/client": "^11.10.0",
        "@trpc/react-query": "^11.10.0",
        "@trpc/server": "^11.10.0",
        "firebase-admin": "^13.6.1",
        "js-cookie": "^3.0.5",
        "jsonwebtoken": "^9.0.3",
        "merge": "^2.1.1",
        "next": "16.1.6",
        "react": "19.2.3",
        "react-dom": "19.2.3",
